# VIT-45 — offline CI for health-mcp-starter (pytest + mcporter gates)
# Copy to .github/workflows/vitaside-ci.yml (requires GitHub token with `workflow` scope to push)
name: VitaSide CI

on:
  push:
    branches: [main, master, integration/**]
    paths:
      - "code/health-mcp-starter/**"
      - ".github/workflows/vitaside-ci.yml"
  pull_request:
    paths:
      - "code/health-mcp-starter/**"
      - ".github/workflows/vitaside-ci.yml"

concurrency:
  group: vitaside-ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  offline-tests:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: code/health-mcp-starter
    env:
      OMI_VAULT_PATH: ${{ github.workspace }}/code/health-mcp-starter/demo-data/vault
      VITASIDE_MANIFEST: ${{ github.workspace }}/code/health-mcp-starter/sidecars/sleep-stress-sidecar/manifest.yaml
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip
          cache-dependency-path: |
            code/health-mcp-starter/requirements.txt
            code/health-mcp-starter/requirements-dev.txt

      - uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Install Python deps
        run: make deps PYTHON=python

      - name: Issue demo sidecar (TTL)
        run: make issue-sidecars PYTHON=python

      - name: Pytest + sidecar_protocol coverage (>=80%)
        run: make pytest PYTHON=python

      - name: mcporter smoke (test-mcporter.sh)
        run: make mcporter PYTHON=python

      - name: Expired manifest fail-closed
        run: make expired PYTHON=python

      - name: MCP self-test
        run: make mcp-selftest PYTHON=python
